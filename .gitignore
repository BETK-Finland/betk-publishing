# Repo for GitHub Pages — deployed via GitHub Actions (no build artifacts in git).
# Patterns starting with `/` are anchored to the repo root so they don't
# accidentally match nested folders (e.g. ui/src/data/).

# Build output (deployed by CI, not committed)
/docs/

# Top-level directories not needed
/.claude/
/mcp/
/plans/

# Top-level files not needed
/CLAUDE.MD

# Node / Astro build artifacts
ui/node_modules/
ui/dist/
ui/.astro/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# Minimal repo for GitHub Pages: only `ui/` (source) + `docs/` (served site).
# Everything else at the root is excluded until it's cleaned up.
# Patterns starting with `/` are anchored to the repo root so they don't
# accidentally match nested folders (e.g. ui/src/data/).

# Top-level directories not needed for GitHub Pages
/.claude/
/data/
/mapping/
/mcp/
/plans/
/schema/

# Top-level files not needed
/CLAUDE.MD

# Node / Astro build artifacts
ui/node_modules/
ui/dist/
ui/.astro/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

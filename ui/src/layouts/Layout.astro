---
import "../styles/global.css";
import { translations } from "../i18n";

interface Props {
	title?: string;
	bodyClass?: string;
}

const { title = "BETK — Betonielementin toimitusketju", bodyClass = "" } = Astro.props;
// BASE_URL is "/betk-publishing/" in production and "/" in dev; trailing slash
// included, so string concat yields correct asset URLs without double-slashes.
const base = import.meta.env.BASE_URL;
---

<html lang="fi">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}betk-logo.svg`} />
		<link rel="shortcut icon" href={`${base}betk-logo.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<div class="app-shell">
			<header class="app-header">
				<div class="app-header-row">
					<div class="app-brand">
						<a href={`${base}`} class="app-logo-link">
							<img src={`${base}betk-logo.svg`} alt="BETK" class="app-logo" width="44" height="43" />
						</a>
						<h1>{title}</h1>
					</div>
					<div class="lang-switcher" aria-label="Kielivalinta">
						<button class="lang-btn" data-lang="fi">FI</button>
						<button class="lang-btn" data-lang="sv">SV</button>
						<button class="lang-btn" data-lang="en">EN</button>
					</div>
				</div>
				<nav class="app-nav">
					<a href={`${base}`} data-i18n="nav.home">Etusivu</a>
					<a href={`${base}properties`} data-i18n="nav.properties">Ominaisuudet</a>
					<a href={`${base}propertysets`} data-i18n="nav.propertysets">Ominaisuusryhmät</a>
					<a href={`${base}soveltamisohje/tarjousvaiheen-tietomaaritykset`} data-i18n="nav.documents">Soveltamisohjeet</a>
					<a href={`${base}peppol`} data-i18n="nav.peppol">Peppol</a>
					<a href={`${base}sanasto`} data-i18n="nav.glossary">Sanasto</a>
					<a href={`${base}esimerkkimallit`} class="nav-right" data-i18n="nav.examples">Esimerkkimallit</a>
				</nav>
			</header>
			<main class="app-body">
				<slot />
			</main>
		</div>
	</body>
</html>

<script define:vars={{ translations }}>
  const LANGS = ["fi", "sv", "en"];
  const STORAGE_KEY = "betk-lang";

  function getLang() {
    const stored = localStorage.getItem(STORAGE_KEY);
    return LANGS.includes(stored) ? stored : "fi";
  }

  function applyLang(lang) {
    // Update html[lang]
    document.documentElement.lang = lang;

    // Translate all data-i18n elements
    const t = translations[lang] || translations["fi"];
    document.querySelectorAll("[data-i18n]").forEach(el => {
      const key = el.getAttribute("data-i18n");
      if (key && t[key]) el.textContent = t[key];
    });

    // Highlight active lang button
    document.querySelectorAll(".lang-btn").forEach(btn => {
      btn.classList.toggle("active", btn.dataset.lang === lang);
    });

    // Show/hide language-specific document links
    document.querySelectorAll("[data-sov-lang]").forEach(el => {
      const docLang = el.getAttribute("data-sov-lang");
      const show = lang === "en" ? docLang === "en" : docLang !== "en";
      /** @type {HTMLElement} */ (el).style.display = show ? "" : "none";
    });
  }

  function setLang(lang) {
    localStorage.setItem(STORAGE_KEY, lang);
    applyLang(lang);
    // Notify sanasto page if it's listening
    window.dispatchEvent(new CustomEvent("betk-lang-change", { detail: lang }));
  }

  // Wire up buttons
  document.querySelectorAll(".lang-btn").forEach(btn => {
    btn.addEventListener("click", () => setLang(btn.dataset.lang));
  });

  // Apply stored language on every page load
  applyLang(getLang());

  // Expose for sanasto page integration
  window.betkSetLang = setLang;
  window.betkGetLang = getLang;
</script>

<style>
  .app-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  /* Push the Esimerkkimallit link to the right edge of the nav row. */
  .app-nav .nav-right {
    margin-left: auto;
  }

  .app-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .app-logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .app-logo {
    display: block;
    height: 44px;
    width: auto;
  }

  .lang-switcher {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .lang-btn {
    padding: 3px 8px;
    font-size: 11px;
    font-family: var(--font-sans);
    letter-spacing: 0.06em;
    font-weight: 500;
    background: none;
    border: 1px solid var(--separator);
    border-radius: 3px;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 120ms, border-color 120ms, background 120ms;
  }

  .lang-btn:hover {
    color: var(--text-strong);
    border-color: var(--text-muted);
  }

  .lang-btn.active {
    color: var(--accent-teal);
    border-color: var(--accent-teal);
    background: rgba(94, 234, 212, 0.08);
  }

  @media screen and (max-width: 640px) {
    .app-header-row {
      flex-wrap: wrap;
      gap: 8px;
    }

    .lang-switcher {
      order: 1;
    }
  }
</style>

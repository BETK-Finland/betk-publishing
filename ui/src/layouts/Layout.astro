---
import "../styles/global.css";
import { translations } from "../i18n";

interface Props {
	title?: string;
	bodyClass?: string;
}

const { title = "BETK — Betonielementin toimitusketju", bodyClass = "" } = Astro.props;
// BASE_URL is "/betk-publishing/" in production and "/" in dev; trailing slash
// included, so string concat yields correct asset URLs without double-slashes.
const base = import.meta.env.BASE_URL;
---

<html lang="fi">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}betk-logo.svg`} />
		<link rel="shortcut icon" href={`${base}betk-logo.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<div class="app-shell">
			<header class="app-header">
				<div class="app-header-row">
					<div class="app-brand">
						<a href={`${base}`} class="app-logo-link">
							<img src={`${base}betk-logo.svg`} alt="BETK" class="app-logo" width="44" height="43" />
						</a>
						<h1>{title}</h1>
					</div>
					<div class="lang-switcher" aria-label="Kielivalinta">
						<button class="lang-btn" data-lang="fi">FI</button>
						<button class="lang-btn" data-lang="sv">SV</button>
						<button class="lang-btn" data-lang="en">EN</button>
					</div>
				</div>
				<nav class="app-nav">
					<a href={`${base}`} data-i18n="nav.home">Etusivu</a>
					<a href={`${base}properties`} data-i18n="nav.properties">Ominaisuudet</a>
					<a href={`${base}propertysets`} data-i18n="nav.propertysets">Ominaisuusryhmät</a>
					<a href={`${base}soveltamisohje/tarjousvaiheen-tietomaaritykset`} data-i18n="nav.documents">Soveltamisohjeet</a>
					<a href={`${base}sanasto`} data-i18n="nav.glossary">Sanasto</a>
					<a href={`${base}esimerkkimallit`} data-i18n="nav.examples">Esimerkkimallit</a>
				</nav>
			</header>
			<main class="app-body">
				<slot />
			</main>
			<footer class="app-footer">
				<a href="https://github.com/BETK-Finland/betk-publishing" class="gh-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub-repositorio">
					<svg class="gh-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor" width="20" height="20">
						<path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.338 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.444 22 12.021 22 6.484 17.522 2 12 2z"/>
					</svg>
				</a>
			</footer>
	</body>
</html>

<script define:vars={{ translations }}>
  const LANGS = ["fi", "sv", "en"];
  const STORAGE_KEY = "betk-lang";

  function getLang() {
    const stored = localStorage.getItem(STORAGE_KEY);
    return LANGS.includes(stored) ? stored : "fi";
  }

  function applyLang(lang) {
    // Update html[lang]
    document.documentElement.lang = lang;

    // Translate all data-i18n elements
    const t = translations[lang] || translations["fi"];
    document.querySelectorAll("[data-i18n]").forEach(el => {
      const key = el.getAttribute("data-i18n");
      if (key && t[key]) el.textContent = t[key];
    });

    // Highlight active lang button
    document.querySelectorAll(".lang-btn").forEach(btn => {
      btn.classList.toggle("active", btn.dataset.lang === lang);
    });

    // Show/hide language-specific document links
    document.querySelectorAll("[data-sov-lang]").forEach(el => {
      const docLang = el.getAttribute("data-sov-lang");
      const show = lang === "en" ? docLang === "en" : docLang !== "en";
      /** @type {HTMLElement} */ (el).style.display = show ? "" : "none";
    });
  }

  function setLang(lang) {
    localStorage.setItem(STORAGE_KEY, lang);
    applyLang(lang);
    // Notify sanasto page if it's listening
    window.dispatchEvent(new CustomEvent("betk-lang-change", { detail: lang }));
  }

  // Wire up buttons
  document.querySelectorAll(".lang-btn").forEach(btn => {
    btn.addEventListener("click", () => setLang(btn.dataset.lang));
  });

  // Apply stored language on every page load
  applyLang(getLang());

  // Expose for sanasto page integration
  window.betkSetLang = setLang;
  window.betkGetLang = getLang;
</script>

<style>
  .app-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .app-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .app-logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .app-logo {
    display: block;
    height: 44px;
    width: auto;
  }

  .lang-switcher {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }

  .lang-btn {
    padding: 3px 8px;
    font-size: 11px;
    font-family: var(--font-sans);
    letter-spacing: 0.06em;
    font-weight: 500;
    background: none;
    border: 1px solid var(--separator);
    border-radius: 3px;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 120ms, border-color 120ms, background 120ms;
  }

  .lang-btn:hover {
    color: var(--text-strong);
    border-color: var(--text-muted);
  }

  .lang-btn.active {
    color: var(--accent-teal);
    border-color: var(--accent-teal);
    background: rgba(94, 234, 212, 0.08);
  }

  @media screen and (max-width: 640px) {
    .app-header-row {
      flex-wrap: wrap;
      gap: 8px;
    }

    .lang-switcher {
      order: 1;
    }
  }

  .app-footer {
    display: flex;
    justify-content: center;
    padding: 16px;
    border-top: 1px solid var(--separator);
  }

  .gh-link {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: color 120ms;
  }

  .gh-link:hover {
    color: var(--text-strong);
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import Sidebar, { type ColumnToggle } from "../components/Sidebar.astro";
import ProductTree from "../components/ProductTree.astro";
import DetailModal from "../components/DetailModal.astro";
import { tree } from "../data/loader";
import IssueTicket from "../components/IssueTicket.astro";

const columns: ColumnToggle[] = [
	{ label: "TUOTEOSAN NIMI", column: "name", defaultChecked: true },
	{ label: "TUNNUS", column: "generalId", defaultChecked: true },
	{ label: "VERSIO", column: "version", defaultChecked: true },
	{ label: "ID", column: "id", defaultChecked: true },
	{ label: "LINKKI", column: "uri", defaultChecked: true },
	{ label: "KUVAUS", column: "description", defaultChecked: false },
];
---

<Layout title="BETK — Properties" bodyClass="hide-col-description">
	<div class="app-main">
		<Sidebar columns={columns} alwaysOnLabel="TIEDOT" />
		<section class="tree-pane">
			<ProductTree tree={tree} />
		</section>
	</div>
	<DetailModal />
	<IssueTicket />
</Layout>

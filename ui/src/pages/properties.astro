---
import Layout from "../layouts/Layout.astro";
import Sidebar, { type ColumnToggle } from "../components/Sidebar.astro";
import ProductTree from "../components/ProductTree.astro";
import DetailModal from "../components/DetailModal.astro";
import { tree } from "../data/loader";
import IssueTicket from "../components/IssueTicket.astro";

const columns: ColumnToggle[] = [
	{ label: "TUOTEOSAN NIMI", column: "name", defaultChecked: true, i18nKey: "col.name" },
	{ label: "TUNNUS", column: "generalId", defaultChecked: true, i18nKey: "col.generalId" },
	{ label: "VERSIO", column: "version", defaultChecked: true, i18nKey: "col.version" },
	{ label: "ID", column: "id", defaultChecked: true, i18nKey: "col.id" },
	{ label: "LINKKI", column: "uri", defaultChecked: true, i18nKey: "col.uri" },
	{ label: "KUVAUS", column: "description", defaultChecked: false, i18nKey: "col.description" },
];
---

<Layout title="BETK — Ominaisuudet" bodyClass="hide-col-description">
	<div class="app-main">
		<Sidebar columns={columns} alwaysOnLabel="TIEDOT" />
		<section class="tree-pane">
			<ProductTree tree={tree} />
		</section>
	</div>
	<DetailModal />
	<IssueTicket />
</Layout>

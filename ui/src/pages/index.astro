---
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ProseSection from "../components/ProseSection.astro";
import PrintToc from "../components/PrintToc.astro";
import IssueTicket from "../components/IssueTicket.astro";
import { listDocs } from "../data/soveltamisohje-loader";
import { getLandingMeta, getLandingManifest } from "../data/landing-loader";

const meta = getLandingMeta();
const manifest = getLandingManifest();
const base = import.meta.env.BASE_URL;
const docs = listDocs();

interface NavLink {
  href: string;
  label: string;
}

const navLinks: NavLink[] = [
  { href: `${base}properties`, label: "Properties" },
  { href: `${base}propertysets`, label: "Property-sets" },
  ...docs.map(d => ({
    href: `${base}soveltamisohje/${d.slug}`,
    label: d.manifest.nav_title,
  })),
];

const entries = await getCollection("landing");
const byId = new Map(entries.map(e => [e.id, e]));

type Rendered = {
  anchor: string;
  sectionNumber: string;
  title: string;
  Content: any;
};

async function resolveSection(section: typeof manifest.sections[number]): Promise<Rendered | null> {
  const entry = byId.get(section.content);
  if (!entry) return null;
  const { Content } = await render(entry);
  return {
    anchor: section.anchor,
    sectionNumber: entry.data.section,
    title: entry.data.title,
    Content,
  };
}

const resolved = (await Promise.all(manifest.sections.map(resolveSection))).filter(
  (r): r is Rendered => r !== null,
);

const tocItems = resolved.map(r => ({ label: `${r.sectionNumber} ${r.title}` }));
---

<Layout title={meta.otsikko}>
  <div class="app-main">
    <aside class="sidebar">
      <section class="column-filter">
        <h2 class="sidebar-heading">NAVIGAATIO</h2>
        <ul class="landing-nav-list">
          {navLinks.map(link => (
            <li><a class="landing-nav-link" href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </section>
    </aside>
    <section class="landing-body">
      <article class="sov-document">
        <header class="sov-header">
          <h1 class="sov-title">{meta.otsikko}</h1>
          {meta.alaotsikko && <p class="sov-subtitle"><strong>{meta.alaotsikko}</strong></p>}
          {meta.paivamaara && (
            <div class="sov-meta"><p>Päivämäärä: {meta.paivamaara}</p></div>
          )}
          <p class="sov-print-date" aria-hidden="true"></p>
        </header>
        <PrintToc sections={tocItems} />
        {resolved.map(r => (
          <ProseSection id={r.anchor} sectionNumber={r.sectionNumber} title={r.title}>
            <r.Content />
          </ProseSection>
        ))}
      </article>
    </section>
  </div>
  <IssueTicket />
</Layout>

<script>
  // Print date stamp — set on beforeprint, visible only in print CSS
  const el = document.querySelector(".sov-print-date");
  if (el) {
    window.addEventListener("beforeprint", () => {
      el.textContent = `Tulostettu: ${new Date().toLocaleDateString("fi-FI")}`;
    });
  }
  // Force all <details> open before print
  window.addEventListener("beforeprint", () => {
    document.querySelectorAll("details").forEach(d => d.setAttribute("open", ""));
  });
</script>

<style>
  .landing-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .landing-nav-list li {
    margin-bottom: 0.5rem;
  }
  .landing-nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    color: inherit;
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: background-color 0.1s, border-color 0.1s;
  }
  .landing-nav-link:hover {
    background-color: rgba(0, 0, 0, 0.05);
    border-left-color: currentColor;
  }
  .landing-body {
    padding: 2rem;
    overflow-y: auto;
  }
</style>

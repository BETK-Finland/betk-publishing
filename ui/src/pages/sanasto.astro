---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Digisanasto — BETK">
  <div class="sn-page">
    <div class="sn-toolbar">
      <input id="search" class="sn-search" placeholder="Hae käsitettä..." />
      <div class="sn-dropdown">
        <button id="langBtn" class="sn-dropbtn">FI</button>
        <div class="sn-dropdown-menu">
          <button onclick="setLang('fi')">Suomi</button>
          <button onclick="setLang('sv')">Svenska</button>
          <button onclick="setLang('en')">English</button>
        </div>
      </div>
      <div class="sn-dropdown">
        <button class="sn-dropbtn">Export</button>
        <div class="sn-dropdown-menu">
          <button onclick="exportJSONLD()">JSON-LD</button>
        </div>
      </div>
    </div>

    <div class="sn-layout">
      <div class="sn-list-panel">
        <div id="list" class="sn-list"></div>
      </div>
      <div id="view" class="sn-view-panel"></div>
    </div>
  </div>

  <style is:global>
    .sn-page {
      margin: -24px -28px;
      display: flex;
      flex-direction: column;
    }

    .sn-toolbar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--separator);
      flex-shrink: 0;
    }

    .sn-search {
      width: 240px;
      padding: 5px 10px;
      background: var(--bg);
      border: 1px solid var(--separator);
      border-radius: 4px;
      color: var(--text);
      font-family: var(--font-sans);
      font-size: 13px;
    }

    .sn-search::placeholder { color: var(--text-muted); }
    .sn-search:focus { outline: 1px solid var(--accent-teal); border-color: var(--accent-teal); }

    .sn-dropdown { position: relative; }

    .sn-dropbtn {
      padding: 5px 12px;
      background: var(--surface-raised);
      border: 1px solid var(--separator);
      border-radius: 4px;
      color: var(--text);
      cursor: pointer;
      font-size: 12px;
      font-family: var(--font-sans);
      letter-spacing: 0.04em;
    }

    .sn-dropbtn:hover { border-color: var(--accent-teal); color: var(--accent-teal); }

    .sn-dropdown-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      margin-top: 2px;
      background: var(--surface-raised);
      border: 1px solid var(--separator);
      border-radius: 4px;
      z-index: 20;
      min-width: 130px;
    }

    .sn-dropdown:hover .sn-dropdown-menu { display: block; }

    .sn-dropdown-menu button {
      display: block;
      width: 100%;
      padding: 7px 14px;
      background: none;
      border: none;
      color: var(--text);
      text-align: left;
      cursor: pointer;
      font-size: 13px;
      font-family: var(--font-sans);
    }

    .sn-dropdown-menu button:hover {
      background: rgba(94, 234, 212, 0.08);
      color: var(--accent-teal);
    }

    .sn-layout {
      display: grid;
      grid-template-columns: 300px 1fr;
    }

    .sn-list-panel {
      border-right: 1px solid var(--separator);
      overflow-y: auto;
      max-height: 80vh;
    }

    .sn-list .item {
      padding: 8px 14px;
      border-bottom: 1px solid var(--separator);
      font-size: 13px;
    }

    .sn-list .item a {
      color: var(--accent-blue);
      text-decoration: none;
      display: block;
    }

    .sn-list .item a:hover { color: var(--accent-teal); }

    .sn-view-panel {
      padding: 24px 28px;
      overflow-y: auto;
      max-height: 80vh;
    }

    .sn-view-panel h1 {
      font-size: 20px;
      color: var(--text-strong);
      margin: 0 0 16px;
    }

    .sn-view-panel h3 {
      font-size: 13px;
      font-weight: 600;
      color: var(--accent-teal);
      margin: 20px 0 8px;
      letter-spacing: 0.04em;
    }

    .sn-view-panel .section { margin-top: 18px; }

    .sn-view-panel .infoBox {
      border: 1px solid var(--separator);
      border-radius: 4px;
      background: var(--surface);
      padding: 10px 14px;
      margin-top: 6px;
      font-size: 13px;
    }

    .sn-view-panel table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    .sn-view-panel th {
      text-align: left;
      padding: 6px 10px;
      border-bottom: 1px solid var(--separator);
      color: var(--text-muted);
      font-size: 11px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      background: var(--surface-raised);
    }

    .sn-view-panel td {
      padding: 7px 10px;
      border-bottom: 1px solid var(--separator);
    }

    .sn-view-panel .link {
      color: var(--accent-blue);
      text-decoration: none;
    }

    .sn-view-panel .link:hover { color: var(--accent-teal); text-decoration: underline; }

    .sn-view-panel .feedbackBox {
      margin-top: 24px;
      padding-top: 12px;
      border-top: 1px solid var(--separator);
    }

    .sn-view-panel .feedbackHint {
      color: var(--text-muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .sn-view-panel p {
      margin: 0 0 10px;
      font-size: 14px;
      line-height: 1.6;
      color: var(--text);
    }

    .sn-view-panel ul {
      margin: 0 0 10px;
      padding-left: 20px;
      font-size: 14px;
      line-height: 1.7;
      color: var(--text);
    }

    .sn-view-panel b,
    .sn-view-panel strong { color: var(--text-strong); }

    .sn-view-panel a { color: var(--accent-blue); }
    .sn-view-panel a:hover { color: var(--accent-teal); }
  </style>

  <script>
    const SANASTO_DATA_URL =
      "https://raw.githubusercontent.com/TeemuAlaluusua/sanasto/refs/heads/main/docs/sanasto.jsonld";
    const ISSUE_REPO = "https://github.com/TeemuAlaluusua/sanasto1/issues/new";
    const BASE_URI = "https://teemualaluusua.github.io/sanasto1/#/concept/";

    const UI = {
      fi: {
        select: "Valitse käsite",
        terms: "Termit", lang: "Kieli", term: "Termi", type: "Tyyppi",
        termType: {
          "Suositettava termi": "Suositettava termi",
          "Synonyymi": "Synonyymi",
          "Lyhenne": "Lyhenne"
        },
        def: "Määritelmä", note: "Huomautus", src: "Lähteet",
        rel: "Liittyvät käsitteet",
        fb: "Voit antaa palautetta käsitteestä sanaston vastuuorganisaatiolle.",
        fbLink: "Anna palautetta käsitteestä",
        homeTitle: "Rakennusalan digisanasto",
        homeAbout: "Tietoa sanastosta",
        homeText1: "Rakennusalan digisanasto kokoaa digitaaliseen rakennettuun ympäristöön liittyviä keskeisiä käsitteitä ja termejä.",
        homeText2: "Sanasto on epävirallinen ja se on laadittu osana väitöskirjatutkimusta.",
        homeAuthor: "Tekijä",
        homeUsage: "Sanaston käyttö",
        homeScope: "Sanaston laajuus",
        homeFeedback: "Voit antaa palautetta sanastosta tai ehdottaa uusia käsitteitä.",
        homeFeedbackBtn: "Anna palautetta sanastosta",
      },
      sv: {
        select: "Välj begrepp",
        terms: "Termer", lang: "Språk", term: "Term", type: "Typ",
        termType: {
          "Suositettava termi": "Rekommenderad term",
          "Synonyymi": "Synonym",
          "Lyhenne": "Förkortning"
        },
        def: "Definition", note: "Anmärkning", src: "Källor",
        rel: "Relaterade begrepp",
        fb: "Du kan ge respons om begreppet till terminologins ansvariga organisation.",
        fbLink: "Ge respons om begreppet",
        homeTitle: "Byggbranschens digitala ordlista",
        homeAbout: "Om ordlistan",
        homeText1: "Den digitala ordlistan för byggbranschen samlar centrala begrepp och termer kopplade till den digitala byggda miljön.",
        homeText2: "Ordlistan är informell och har skapats som en del av en doktorsavhandling.",
        homeAuthor: "Författare",
        homeUsage: "Hur ordlistan används",
        homeScope: "Ordlistans omfattning",
        homeFeedback: "Du kan ge respons på ordlistan eller föreslå nya begrepp.",
        homeFeedbackBtn: "Ge respons om ordlistan",
      },
      en: {
        select: "Select concept",
        terms: "Terms", lang: "Language", term: "Term", type: "Type",
        termType: {
          "Suositettava termi": "Preferred term",
          "Synonyymi": "Synonym",
          "Lyhenne": "Abbreviation"
        },
        def: "Definition", note: "Note", src: "Sources",
        rel: "Related concepts",
        fb: "You can give feedback on the concept to the terminology owner.",
        fbLink: "Give feedback on the concept",
        homeTitle: "Digital Construction Glossary",
        homeAbout: "About the glossary",
        homeText1: "The digital construction glossary collects key concepts and terms related to the digital built environment.",
        homeText2: "The glossary is informal and created as part of a doctoral research project.",
        homeAuthor: "Author",
        homeUsage: "Using the glossary",
        homeScope: "Glossary scope",
        homeFeedback: "You can give feedback on the glossary or suggest new concepts.",
        homeFeedbackBtn: "Give feedback on the glossary",
      }
    };

    const SCHEME_LABELS = {
      sanasto: { fi: "Sanasto", sv: "Terminologi", en: "Vocabulary" }
    };

    let currentLang = "fi";
    let concepts = [];
    let map = {};

    const toArray = v => v == null ? [] : (Array.isArray(v) ? v : [v]);
    const asId = x => typeof x === "object" ? x["@id"] || "" : x || "";
    const esc = s => String(s || "").replace(/[&<>"']/g,
      a => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[a]));

    fetch(SANASTO_DATA_URL)
      .then(r => r.json())
      .then(j => {
        const graph = j["@graph"] || [];

        concepts = graph
          .filter(n => {
            const t = toArray(n["@type"]);
            return t.includes("skos:Concept") ||
              t.includes("http://www.w3.org/2004/02/skos/core#Concept");
          })
          .map(n => {
            const uri = asId(n["@id"]);
            if (!uri.includes("#/concept/")) return null;
            const id = uri.split("#/concept/").pop();
            return {
              id,
              scheme: toArray(n["skos:inScheme"])
                .map(u => asId(u))
                .map(u => u.includes("#") ? u.split("#").pop() : u.split("/").pop())[0] || "default",
              terms: [
                ...toArray(n["skos:prefLabel"]).map(t => ({
                  lang: t["@language"], label: t["@value"],
                  type: t.termType || "Suositettava termi"
                })),
                ...toArray(n["skos:altLabel"]).map(t => ({
                  lang: t["@language"], label: t["@value"],
                  type: t.termType || "Synonyymi"
                }))
              ],
              defs: toArray(n["skos:definition"]).map(d => ({
                lang: d["@language"], text: d["@value"]
              })),
              notes: toArray(n["skos:note"]).map(d => ({
                lang: d["@language"], text: d["@value"]
              })),
              sources: toArray(n["dcterms:source"]).map(s => ({
                lang: s["@language"] || "",
                label: s["@value"] || "",
                url: s["@id"] || s["uri"] || ""
              })),
              related: toArray(n["skos:related"])
                .map(u => asId(u))
                .filter(u => u.includes("#/concept/"))
                .map(u => u.split("#/concept/").pop())
            };
          })
          .filter(Boolean);

        concepts.forEach((c, i) => (map[c.id] = i));

        renderHome();
        renderList();
        openFromHash();
      });

    function setLang(l) {
      currentLang = l;
      document.getElementById("langBtn").textContent = l.toUpperCase();
      renderList();
      const m = location.hash.match(/^#\/concept\/(.+)$/);
      if (m) {
        renderConcept(decodeURIComponent(m[1]));
      } else {
        renderHome();
      }
    }

    function term(c) {
      return c.terms.find(t => t.lang === currentLang) || c.terms[0];
    }

    function renderList() {
      const q = document.getElementById("search").value.toLowerCase();
      const el = document.getElementById("list");
      el.innerHTML = "";

      const groups = {};
      concepts.forEach(c => {
        const termsInLang = c.terms.filter(t => t.lang === currentLang);
        if (termsInLang.length === 0) return;
        if (!termsInLang.some(t => t.label.toLowerCase().includes(q))) return;
        if (!groups[c.scheme]) groups[c.scheme] = [];
        groups[c.scheme].push(c);
      });

      Object.keys(groups).sort().forEach(scheme => {
        const header = document.createElement("div");
        header.className = "item";
        Object.assign(header.style, {
          fontWeight: "700",
          fontSize: "11px",
          letterSpacing: "0.06em",
          textTransform: "uppercase",
          color: "var(--text-muted)",
          background: "var(--surface)",
        });
        header.textContent = SCHEME_LABELS[scheme]?.[currentLang] || scheme;
        el.appendChild(header);

        groups[scheme]
          .sort((a, b) => term(a).label.localeCompare(term(b).label, currentLang))
          .forEach(c => {
            const div = document.createElement("div");
            div.className = "item";
            const a = document.createElement("a");
            a.href = "#/concept/" + encodeURIComponent(c.id);
            a.onclick = e => {
              e.preventDefault();
              location.hash = "#/concept/" + encodeURIComponent(c.id);
              renderConcept(c.id);
            };
            const abbr = c.terms.find(
              t => t.lang === currentLang && t.type === "Lyhenne"
            );
            a.textContent = abbr
              ? `${term(c).label} (${abbr.label})`
              : term(c).label;
            div.appendChild(a);
            el.appendChild(div);
          });
      });
    }

    function renderHome() {
      const t = UI[currentLang];
      const issueURL = ISSUE_REPO + "?title=Glossary feedback";
      document.getElementById("view").innerHTML = `
<h1>${t.homeTitle}</h1>
<div class="section">
  <h3>${t.homeAbout}</h3>
  <p>${t.homeText1}</p>
  <p><b>${t.homeText2}</b></p>
</div>
<div class="section">
  <h3>${t.homeAuthor}</h3>
  <p>Teemu Alaluusua</p>
</div>
<div class="section">
  <h3>${t.homeUsage}</h3>
  <ul>
    <li>Valitse käsite vasemman reunan listasta</li>
    <li>Voit hakea käsitteitä hakukentällä</li>
    <li>Käsitteestä näet termit eri kielillä</li>
    <li>Määritelmät ja huomautukset näkyvät käsitenäkymässä</li>
  </ul>
</div>
<div class="section">
  <h3>${t.homeScope}</h3>
  <p>${concepts.length}</p>
</div>
<div class="feedbackBox">
  <div class="feedbackHint">${t.homeFeedback}</div>
  <div><a class="link" href="${issueURL}" target="_blank">${t.homeFeedbackBtn} ↗</a></div>
</div>`;
    }

    function renderConcept(id) {
      const c = concepts[map[id]];
      if (!c) return;
      const t = UI[currentLang];
      const label = term(c)?.label || id;

      const LANG_ORDER = { fi: ["fi", "sv", "en"], sv: ["sv", "fi", "en"], en: ["en", "fi", "sv"] };
      const order = LANG_ORDER[currentLang] || ["fi", "sv", "en"];

      const termsRows = [...c.terms]
        .sort((a, b) => {
          const ai = order.indexOf(a.lang);
          const bi = order.indexOf(b.lang);
          return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
        })
        .map(tr => `<tr><td>${esc(tr.lang)}</td><td>${esc(tr.label)}</td><td>${esc(UI[currentLang].termType[tr.type] || tr.type)}</td></tr>`)
        .join("");

      const defs = c.defs.length
        ? `<table><tr><th>${t.lang}</th><th>${t.def}</th></tr>${
            c.defs.map(d => `<tr><td style="width:60px">${esc(d.lang)}</td><td>${esc(d.text)}</td></tr>`).join("")
          }</table>`
        : "—";

      const notes = c.notes.length
        ? `<table><tr><th>${t.lang}</th><th>${t.note}</th></tr>${
            c.notes.map(d => `<tr><td style="width:60px">${esc(d.lang)}</td><td>${esc(d.text)}</td></tr>`).join("")
          }</table>`
        : "—";

      const src = c.sources.length
        ? c.sources.map(s => s.url
            ? `<div><a class="link" href="${esc(s.url)}" target="_blank">${esc(s.label)}</a></div>`
            : `<div>${esc(s.label)}</div>`
          ).join("")
        : "—";

      const rel = c.related
        .map(r => {
          const rc = concepts[map[r]];
          if (!rc) return "";
          return `<li><a class="link" href="#/concept/${encodeURIComponent(r)}" onclick="renderConcept('${r.replace(/'/g, "\\'")}');return false;">${esc(term(rc).label)}</a></li>`;
        })
        .filter(Boolean)
        .join("");

      const issueURL = ISSUE_REPO + "?title=" + encodeURIComponent(label);

      document.getElementById("view").innerHTML = `
<h1>${esc(label)}</h1>
<div class="section">
  <b>URI</b><br>
  <a class="link" href="${BASE_URI}${encodeURIComponent(id)}">${BASE_URI}${esc(id)}</a>
</div>
<div class="section">
  <h3>${t.terms}</h3>
  <table>
    <tr><th>${t.lang}</th><th>${t.term}</th><th>${t.type}</th></tr>
    ${termsRows}
  </table>
</div>
<div class="section">
  <h3>${t.def}</h3>
  <div class="infoBox">${defs}</div>
</div>
<div class="section">
  <h3>${t.note}</h3>
  <div class="infoBox">${notes}</div>
</div>
<div class="section">
  <h3>${t.src}</h3>
  <div class="infoBox">${src}</div>
</div>
<div class="section">
  <h3>${t.rel}</h3>
  <div class="infoBox"><ul>${rel}</ul></div>
</div>
<div class="feedbackBox">
  <div class="feedbackHint">${t.fb}</div>
  <div><a class="link" href="${issueURL}" target="_blank">${t.fbLink} ↗</a></div>
</div>`;
    }

    function openFromHash() {
      const m = location.hash.match(/^#\/concept\/(.+)$/);
      if (!m) return;
      const id = decodeURIComponent(m[1]).trim();
      if (map[id] !== undefined) { renderConcept(id); return; }
      const slug = id.replace(/\s+/g, "-");
      if (map[slug] !== undefined) { renderConcept(slug); }
    }

    window.addEventListener("hashchange", openFromHash);
    document.getElementById("search").addEventListener("input", renderList);

    function exportJSONLD() {
      const a = document.createElement("a");
      a.href = SANASTO_DATA_URL;
      a.download = "sanasto.jsonld";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    }
  </script>
</Layout>

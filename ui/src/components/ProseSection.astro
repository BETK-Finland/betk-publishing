---
interface Props {
  id: string;
  sectionNumber: string;
  title: string;
}
const { id, sectionNumber, title } = Astro.props;
const headingTag = sectionNumber.includes(".") ? "h4" : "h2";
---

<section id={id} class="sov-section">
  {headingTag === "h2" ? (
    <h2>{sectionNumber} {title}</h2>
  ) : (
    <h4>{sectionNumber} {title}</h4>
  )}
  <div class="sov-prose">
    <slot />
  </div>
</section>

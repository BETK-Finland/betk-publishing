---
// Column filter sidebar. Source of truth for which columns are visible.
// Each checkbox carries data-column="<table key>"; the body class
// hide-col-<key> is applied when the checkbox is unchecked. Styles that
// hide columns live in global.css.

export interface ColumnToggle {
	label: string;
	column: string;
	defaultChecked: boolean;
	i18nKey?: string;
}

interface Props {
	columns: ColumnToggle[];
	heading?: string;
	alwaysOnLabel?: string;
}

const {
	columns,
	heading = "SARAKKEIDEN SUODATUS",
	alwaysOnLabel,
} = Astro.props;

const headingKey = heading === "SARAKKEIDEN SUODATUS" ? "sidebar.columns"
  : heading === "NAVIGAATIO" ? "sidebar.navigation"
  : null;
---

<aside class="sidebar">
	<section class="column-filter">
		<h2 class="sidebar-heading" data-i18n={headingKey || undefined}>{heading}</h2>
		<ul class="column-filter-list">
			{columns.map((col) => (
				<li>
					<label class="checkbox-row">
						<input
							type="checkbox"
							class="column-toggle"
							data-column={col.column}
							checked={col.defaultChecked}
						/>
						<span data-i18n={col.i18nKey}>{col.label}</span>
					</label>
				</li>
			))}
			{alwaysOnLabel && (
				<li class="always-on">
					<span class="checkbox-row">
						<span class="always-on-indicator" aria-hidden="true">●</span>
						<span data-i18n={alwaysOnLabel === "TIEDOT" ? "sidebar.data" : undefined}>{alwaysOnLabel}</span>
					</span>
				</li>
			)}
		</ul>
	</section>
</aside>

<script>
	// Keep body.hide-col-<key> in sync with each checkbox. Runs once on load so
	// the initial render matches the declared defaults, then again on every change.
	function syncColumn(checkbox: HTMLInputElement) {
		const col = checkbox.dataset.column;
		if (!col) return;
		document.body.classList.toggle(`hide-col-${col}`, !checkbox.checked);
	}

	const checkboxes = document.querySelectorAll<HTMLInputElement>(".column-toggle");
	checkboxes.forEach((cb) => {
		syncColumn(cb);
		cb.addEventListener("change", () => syncColumn(cb));
	});
</script>

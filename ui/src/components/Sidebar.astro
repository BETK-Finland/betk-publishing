---
// Column filter sidebar. Source of truth for which columns are visible.
// Each checkbox carries data-column="<table key>"; the body class
// hide-col-<key> is applied when the checkbox is unchecked. Styles that
// hide columns live in global.css.

export interface ColumnToggle {
	label: string;
	column: string;
	defaultChecked: boolean;
	i18nKey?: string;
}

interface Props {
	columns: ColumnToggle[];
	heading?: string;
	alwaysOnLabel?: string;
}

const {
	columns,
	heading = "SARAKKEIDEN SUODATUS",
	alwaysOnLabel,
} = Astro.props;

const headingKey = heading === "SARAKKEIDEN SUODATUS" ? "sidebar.columns"
  : heading === "NAVIGAATIO" ? "sidebar.navigation"
  : null;

// BASE_URL has a trailing slash; concat yields a correct asset URL.
const base = import.meta.env.BASE_URL;
---

<aside class="sidebar">
	<section class="column-filter">
		<h2 class="sidebar-heading" data-i18n={headingKey || undefined}>{heading}</h2>
		<ul class="column-filter-list">
			{columns.map((col) => (
				<li>
					<label class="checkbox-row">
						<input
							type="checkbox"
							class="column-toggle"
							data-column={col.column}
							checked={col.defaultChecked}
						/>
						<span data-i18n={col.i18nKey}>{col.label}</span>
					</label>
				</li>
			))}
			{alwaysOnLabel && (
				<li class="always-on">
					<span class="checkbox-row">
						<span class="always-on-indicator" aria-hidden="true">●</span>
						<span data-i18n={alwaysOnLabel === "TIEDOT" ? "sidebar.data" : undefined}>{alwaysOnLabel}</span>
					</span>
				</li>
			)}
		</ul>
	</section>

	<section class="sidebar-download">
		<h2 class="sidebar-heading" data-i18n="sidebar.files">TIEDOSTOT</h2>
		<a class="sidebar-download-link" href={`${base}BETK_Esimerkkimalli_IFC4x3.ifc`} download>
			<svg class="sidebar-download-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
				<polyline points="7 10 12 15 17 10"/>
				<line x1="12" y1="15" x2="12" y2="3"/>
			</svg>
			<span>BETK Esimerkkimalli IFC4x3.ifc</span>
		</a>
	</section>
</aside>

<style>
	.sidebar-download {
		margin-top: 16px;
		padding-top: 14px;
		border-top: 1px solid var(--separator);
	}

	.sidebar-download-link {
		display: flex;
		align-items: flex-start;
		gap: 8px;
		color: var(--accent-teal);
		text-decoration: none;
		font-size: 12px;
		letter-spacing: 0.04em;
		font-weight: 500;
		line-height: 1.4;
	}

	.sidebar-download-link:hover span {
		text-decoration: underline;
	}

	.sidebar-download-icon {
		flex-shrink: 0;
		margin-top: 1px;
	}

	/* Spacing when more file links are added to the section. */
	.sidebar-download-link + .sidebar-download-link {
		margin-top: 8px;
	}
</style>

<script>
	// Keep body.hide-col-<key> in sync with each checkbox. Runs once on load so
	// the initial render matches the declared defaults, then again on every change.
	function syncColumn(checkbox: HTMLInputElement) {
		const col = checkbox.dataset.column;
		if (!col) return;
		document.body.classList.toggle(`hide-col-${col}`, !checkbox.checked);
	}

	const checkboxes = document.querySelectorAll<HTMLInputElement>(".column-toggle");
	checkboxes.forEach((cb) => {
		syncColumn(cb);
		cb.addEventListener("change", () => syncColumn(cb));
	});
</script>
